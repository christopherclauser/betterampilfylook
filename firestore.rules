rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
                      request.resource.data.keys().hasAll(['username', 'createdAt']) &&
                      request.resource.data.username is string &&
                      request.resource.data.username.size() >= 3 &&
                      request.resource.data.username.size() <= 20;
      allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmin']); // Only server/manual admin set
    }

    // Username uniqueness registry
    match /usernames/{username} {
      allow read: if true; // Needed to check availability
      allow create: if isSignedIn() && 
                      !exists(/databases/$(database)/documents/usernames/$(username)) &&
                      request.resource.data.uid == request.auth.uid;
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Shared screen ripples
    match /pings/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                      request.resource.data.keys().hasAll(['x', 'y', 'author', 'timestamp']) &&
                      request.resource.data.x is number &&
                      request.resource.data.y is number;
    }
  }
}
